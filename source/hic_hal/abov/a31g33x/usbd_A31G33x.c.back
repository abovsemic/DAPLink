void EX_USB_SetEPxHIDConfig(void)
{
    USB_EPX_CFG_t tEPxCfg;
	
#if TEST_SINGLE
    /* EP1 IN */
    tEPxCfg.un8Num = (g_usbHIDConfigDesc.ep_in.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbHIDConfigDesc.ep_in.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbHIDConfigDesc.ep_in.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbHIDConfigDesc.ep_in.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
    
    /* EP1 OUT */    
    tEPxCfg.un8Num = (g_usbHIDConfigDesc.ep_out.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbHIDConfigDesc.ep_out.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbHIDConfigDesc.ep_out.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbHIDConfigDesc.ep_out.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
#else
    /* EP2 IN */
    tEPxCfg.un8Num = (g_usbCompositeConfigDesc.hid_ep_in.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbCompositeConfigDesc.hid_ep_in.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbCompositeConfigDesc.hid_ep_in.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbCompositeConfigDesc.hid_ep_in.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
    
    /* EP2 OUT */    
    tEPxCfg.un8Num = (g_usbCompositeConfigDesc.hid_ep_out.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbCompositeConfigDesc.hid_ep_out.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbCompositeConfigDesc.hid_ep_out.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbCompositeConfigDesc.hid_ep_out.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
#endif

}

void EX_USB_SetEPxCDCConfig(void)
{
    USB_EPX_CFG_t tEPxCfg;

#if TEST_SINGLE
    /* EP2 IN */
    tEPxCfg.un8Num = (g_usbCDCConfigDesc.ep_in.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbCDCConfigDesc.ep_in.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbCDCConfigDesc.ep_in.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbCDCConfigDesc.ep_in.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
    
    /* EP2 OUT */    
    tEPxCfg.un8Num = (g_usbCDCConfigDesc.ep_out.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbCDCConfigDesc.ep_out.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbCDCConfigDesc.ep_out.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbCDCConfigDesc.ep_out.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
#else
    /* EP1 IN */
    tEPxCfg.un8Num = (g_usbCompositeConfigDesc.cdc_ep_in.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbCompositeConfigDesc.cdc_ep_in.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbCompositeConfigDesc.cdc_ep_in.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbCompositeConfigDesc.cdc_ep_in.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
    
    /* EP1 OUT */    
    tEPxCfg.un8Num = (g_usbCompositeConfigDesc.cdc_ep_out.bEndpointAddress & 0x0F);
    tEPxCfg.bDir = (g_usbCompositeConfigDesc.cdc_ep_out.bEndpointAddress & 0x80 ? true : false);
    tEPxCfg.un16PktSize = g_usbCompositeConfigDesc.cdc_ep_out.wMaxPacketSize;
    tEPxCfg.un8Attr = g_usbCompositeConfigDesc.cdc_ep_out.bmAttributes;
    
    HAL_USB_SetEPxConfig(USB_ID_0, &tEPxCfg);
#endif

}

void EX_USB_EP0_Stall(void)
{
    s_ep0Tx.pBuf    = NULL;
    s_ep0Tx.total   = 0;
    s_ep0Tx.sent    = 0;
    s_ep0Tx.needZlp = false;

    HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SENDSTALL | USB_EP0_CTRL_DATAEND);
}

void EX_USB_EP0_SendZLP(void)
{
    s_ep0Tx.pBuf   = NULL;
    s_ep0Tx.total  = 0;
    s_ep0Tx.sent   = 0;
    s_ep0Tx.needZlp = false;

    HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_INPKTRDY | USB_EP0_CTRL_DATAEND);
}

static void EX_USB_EP0_TxContinue(void)
{
    uint16_t remain = s_ep0Tx.total - s_ep0Tx.sent;
    uint16_t pktLen = (remain > USB_EP0_MAX_PKT_SIZE) ? USB_EP0_MAX_PKT_SIZE : remain;

    if (pktLen > 0)
    {
        HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SRVOUTPKTRDY);

        HAL_USB_SetEPxFifo(USB_ID_0, 0, &s_ep0Tx.pBuf[s_ep0Tx.sent], pktLen);
        USB_LOG("[S]Send End\n");
        s_ep0Tx.sent += pktLen;

        if (s_ep0Tx.sent >= s_ep0Tx.total)
        {
            HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_INPKTRDY | USB_EP0_CTRL_DATAEND);
        }
        else
        {
            HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_INPKTRDY);
        }
    }
}

static void EX_USB_EP0_RxContinue(void)
{
    uint16_t remain = s_ep0Rx.total - s_ep0Rx.recv;
    uint16_t pktLen = (remain > USB_EP0_MAX_PKT_SIZE) ? USB_EP0_MAX_PKT_SIZE : remain;
    uint16_t rxLen = 0;

    if (pktLen > 0)
    {
        HAL_USB_GetEPxFifoCount(USB_ID_0, 0, &rxLen);

        if (rxLen > pktLen)
            rxLen = pktLen;

        HAL_USB_GetEPxFifo(USB_ID_0, 0, &s_ep0Rx.pBuf[s_ep0Rx.recv], rxLen);

        s_ep0Rx.recv += rxLen;
    }

    if (s_ep0Rx.recv >= s_ep0Rx.total)
    {
        USB_LOG("[S] End Rx!\n");
        HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SRVOUTPKTRDY | USB_EP0_CTRL_DATAEND);
    }
    else
    {
        HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SRVOUTPKTRDY);
    }
}

static void EX_USB_EP0_TxStart(const uint8_t *pData, uint16_t length)
{
    if ((pData == NULL) || (length == 0))
    {
        HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_INPKTRDY | USB_EP0_CTRL_DATAEND);
        return;
    }

    s_ep0Tx.pBuf  = pData;
    s_ep0Tx.total = length;
    s_ep0Tx.sent  = 0;

    s_ep0Tx.needZlp = ((length % USB_EP0_MAX_PKT_SIZE) == 0);

    EX_USB_EP0_TxContinue();
}

static void EX_USB_EP0_RxStart(uint8_t *pData, uint16_t length)
{
    if ((pData == NULL) || (length == 0))
    {
        HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_INPKTRDY | USB_EP0_CTRL_DATAEND);
        return;
    }

    s_ep0Rx.pBuf  = pData;
    s_ep0Rx.total = length;
    s_ep0Rx.recv  = 0;

    EX_USB_EP0_RxContinue();
}

static USB_EP0_Response_t EX_USB_GetStrDesc(const USB_SetupPkt_t *pPkt)
{
    USB_EP0_Response_t tResp = { USB_EP0_RESP_STALL, NULL, 0 };
    uint8_t *pStr = NULL;

    switch(pPkt->un16Val & 0xFF)
    {
        case USB_STRTYPE_LANG: pStr = (uint8_t *)&usb_string_langid;      break;
        case USB_STRTYPE_PRD:  pStr = (uint8_t *)&usb_string_hid_product; break;
        case USB_STRTYPE_VND:  pStr = (uint8_t *)&usb_string_vendor;      break;
        case USB_STRTYPE_SN:   pStr = (uint8_t *)&usb_string_serial;      break;
    }

    if (pStr)
    {
        tResp.type   = USB_EP0_RESP_IN;
        tResp.pData  = pStr;
        uint8_t fullLen = pStr[0];
        tResp.length = (fullLen < pPkt->un16Len) ? fullLen : pPkt->un16Len;
    }
    return tResp;
}

static USB_EP0_Response_t EX_USB_GetDesc(const USB_SetupPkt_t *pPkt)
{
    USB_EP0_Response_t tResp = { USB_EP0_RESP_STALL, NULL, 0 };
    uint8_t descType = (uint8_t)(pPkt->un16Val >> 8); // Descriptor Type (High Byte)
    
    switch(descType)
    {
        case USB_DESCTYPE_DEV: // 0x01: Device Descriptor
            LOG("[S] Get Device Desc\n");
            tResp.type   = USB_EP0_RESP_IN;
            tResp.pData  = (uint8_t *)s_aun8DevDesc;
            tResp.length = DEVICE_DESC_SIZE;
            break;

        case USB_DESCTYPE_CFG: // 0x02: Configuration Descriptor
            LOG("[S] Get Config Desc\n");
            tResp.type = USB_EP0_RESP_IN;
#if TEST_SINGLE
#if (USB_CLASS_TYPE == 1) // CDC
            tResp.pData  = (uint8_t *)&g_usbCDCConfigDesc;
            tResp.length = (pPkt->un16Len == 9) ? 9 : sizeof(g_usbCDCConfigDesc);
#elif (USB_CLASS_TYPE == 2) // HID
            tResp.pData  = (uint8_t *)&g_usbHIDConfigDesc;
            tResp.length = (pPkt->un16Len == 9) ? 9 : sizeof(g_usbHIDConfigDesc);
#endif
#else
            tResp.pData  = (uint8_t *)&g_usbCompositeConfigDesc;
            tResp.length = (pPkt->un16Len == 9) ? 9 : sizeof(g_usbCompositeConfigDesc);
				    LOG("[S] CompositeConfig Len=%d\n", tResp.length);
#endif
            break;

        case USB_DESCTYPE_STR: // 0x03: String Descriptor
            LOG("[S] Get String Desc\n");
            tResp = EX_USB_GetStrDesc(pPkt);
            break;

        case USB_DESCTYPE_HID_REPORT: // 0x22: HID Report Descriptor
            LOG("[S] Get HID Report Desc\n");
            tResp.type   = USB_EP0_RESP_IN;
            tResp.pData  = (uint8_t *)g_HID_ReportDesc;
            tResp.length = sizeof(g_HID_ReportDesc);
            break;

        default:
            LOG("[W] Unknown Desc Type: 0x%02x\n", descType);
            break;
    }

    if (tResp.type == USB_EP0_RESP_IN && tResp.length > pPkt->un16Len)
    {
        tResp.length = pPkt->un16Len;
    }

    return tResp;
}

uint8_t un8Idle = 0, un8Prot = 0;

static USB_EP0_Response_t EX_USB_HandleHIDReq(USB_SetupPkt_t *pPkt)
{
    USB_EP0_Response_t tResp = { USB_EP0_RESP_NONE, NULL, 0 };

    switch(pPkt->un8Req)
    {
        case HID_REQ_GET_REPORT:
            USB_LOG("[S] GREP\n");
            tResp.type   = USB_EP0_RESP_IN;
            tResp.pData = (uint8_t *)&un8Prot;
            tResp.length = 1;
            break;
        case HID_REQ_GET_IDLE:
            USB_LOG("[S] GIDLE\n");
            tResp.type   = USB_EP0_RESP_IN;
            tResp.pData = (uint8_t *)&un8Idle;
            tResp.length = 1;
            break;
        case HID_REQ_SET_REPORT:
            USB_LOG("[S] SREP\n");
            un8Prot = (uint8_t)(pPkt->un16Val & 0xFF);
            tResp.type = USB_EP0_RESP_OUT;
            tResp.pData = NULL;
            tResp.length = pPkt->un16Len;
            break;
        case HID_REQ_SET_IDLE:
            USB_LOG("[S] SIDLE\n");
            un8Idle = (uint8_t)(pPkt->un16Val & 0xFF);
            tResp.type = USB_EP0_RESP_NODATA;
            break;
        case HID_REQ_SET_PROTOCOL:
        case HID_REQ_GET_PROTOCOL:
        default:
            break;
    }

    return tResp;
}

static USB_EP0_Response_t EX_USB_HandleCDCReq(USB_SetupPkt_t *pPkt)
{
    USB_EP0_Response_t tResp = { USB_EP0_RESP_NONE, NULL, 0 };

    switch(pPkt->un8Req)
    {
        case CDC_REQ_SEND_ENCAPSULATED_COMMAND:
        case CDC_REQ_GET_ENCAPSULATED_RESPONSE:
        case CDC_REQ_SET_COMM_FEATURE:
        case CDC_REQ_GET_COMM_FEATURE:
        case CDC_REQ_CLEAR_COMM_FEATURE:
            USB_LOG("[S] CETC!\n");
            tResp.type   = USB_EP0_RESP_STATUS;
            break;
        case CDC_REQ_SET_LINE_CODING:
            USB_LOG("[S] SLC!\n");
            tResp.type = USB_EP0_RESP_STATUS;
            break;
        case CDC_REQ_GET_LINE_CODING:
            USB_LOG("[S] GLC!(%d)\n",sizeof(s_tCdcLineCoding));
            tResp.type = USB_EP0_RESP_IN;
            tResp.pData = (uint8_t *)&s_tCdcLineCoding;
            tResp.length = sizeof(s_tCdcLineCoding);
            break;
        case CDC_REQ_SET_CONTROL_LINE_STATE:
            USB_LOG("[S] SLCS!\n");
            tResp.type   = USB_EP0_RESP_NODATA;
            break;
        case CDC_REQ_SEND_BREAK:
            break;
        default:
            break;
    }

    return tResp;
}

static USB_EP0_Response_t EX_USB_HandleStdReq(USB_SetupPkt_t *pPkt)
{
    USB_EP0_Response_t tResp = { USB_EP0_RESP_STALL, NULL, 0 };

    switch(pPkt->un8Req)
    {
        case USB_STDREQ_DESC:
            tResp = EX_USB_GetDesc(pPkt);
            break;

        case USB_STDREQ_ADDR:
            s_un8FAddr = pPkt->un16Val;
            tResp.type = USB_EP0_RESP_STATUS;
            break;

        case USB_STDREQ_SCFG:
            tResp.type = USB_EP0_RESP_NODATA;
#if TEST_SINGLE
#if (USB_CLASS_TYPE == 1)
            EX_USB_SetEPxCDCConfig();
#else
            EX_USB_SetEPxHIDConfig();
#endif
#else
            EX_USB_SetEPxHIDConfig();
            EX_USB_SetEPxCDCConfig();
#endif
            break;
    }
    return tResp;
}

static void EX_USB_SetSetup(USB_SetupPkt_t *pPkt)
{
    USB_EP0_Response_t tResp = { USB_EP0_RESP_STALL, NULL, 0 };

    switch (pPkt->un8ReqType & USB_BMREQ_MASK_TYPE)
    {
        case USB_REQTYPE_STD:
            tResp = EX_USB_HandleStdReq(pPkt);
            break;

        case USB_REQTYPE_CLS:
#if TEST_SINGLE
#if (USB_CLASS_TYPE == 1)
            tResp = EX_USB_HandleCDCReq(pPkt);
#elif (USB_CLASS_TYPE == 2)
            tResp = EX_USB_HandleHIDReq(pPkt);
#endif
#else
            {
                uint8_t interfaceNum = (uint8_t)(pPkt->un16Idx & 0xFF);

                if (interfaceNum == 0) 
                {
                    USB_LOG("[S] HID Class Req (IF 0)\n");
                    tResp = EX_USB_HandleHIDReq(pPkt);
                } 
                else if (interfaceNum == 1 || interfaceNum == 2) 
                {
                    USB_LOG("[S] CDC Class Req (IF %d)\n");
                    tResp = EX_USB_HandleCDCReq(pPkt);
                }
                else 
                {
                    USB_LOG("[E] Unknown Interface: %d\n", interfaceNum);
                    tResp.type = USB_EP0_RESP_STALL;
                }
						}
#endif

            break;

        case USB_REQTYPE_VND:
            USB_LOG("[S] Vendor Req - Not Supported\n");
            break;
    }

    switch (tResp.type)
    {
        case USB_EP0_RESP_IN:
            EX_USB_EP0_TxStart(tResp.pData, tResp.length);
            break;

        case USB_EP0_RESP_OUT:
            EX_USB_EP0_RxStart(tResp.pData, tResp.length);
            break;

        case USB_EP0_RESP_STATUS:
            HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SRVOUTPKTRDY);
            break;

        case USB_EP0_RESP_NODATA:
            HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SRVOUTPKTRDY | USB_EP0_CTRL_DATAEND);
            break;

        case USB_EP0_RESP_NONE:
            EX_USB_EP0_SendZLP();
            break;

        case USB_EP0_RESP_STALL:
        default:
            USB_LOG("[E] Request Stalled: Req=0x%x\n", pPkt->un8Req);
            EX_USB_EP0_Stall();
            break;
    }
}

static void PRV_USB_HandleEPOut(uint32_t un32Event)
{
    uint16_t un16FifoCount = 0;
    uint8_t un8RxBuf[64];
    uint8_t un8EpNum = 31 - __clz(un32Event);

    HAL_USB_GetEPxFifoCount(USB_ID_0, un8EpNum, &un16FifoCount);
    
    if (un16FifoCount > sizeof(un8RxBuf)) un16FifoCount = sizeof(un8RxBuf);

    HAL_USB_GetEPxFifo(USB_ID_0, un8EpNum, un8RxBuf, un16FifoCount);

    LOG("EP%d RX (%d bytes): ", un8EpNum, un16FifoCount);
    for (int i = 0; i < un16FifoCount; i++)
    {
        LOG("%02X ", un8RxBuf[i]);
    }
    LOG("\n");
}

