/*
 *  USB Device Interrupt Service Routine
 */

static void USB_HW_IRQHandler(uint32_t un32Event, void *pContext)
{
    NVIC_DisableIRQ(USB_IRQn);
    USBD_SignalHandler();
}

#if 0
static enum {
    EP0_STAGE_SETUP,
    EP0_STAGE_DATA_OUT
} ep0_current_stage = EP0_STAGE_SETUP;
#endif

typedef enum {
    EP0_STAGE_IDLE = 0,
    EP0_STAGE_SETUP,
    EP0_STAGE_DATA_OUT,
    EP0_STAGE_DATA_IN,
    EP0_STAGE_STATUS_OUT,
    EP0_STAGE_STATUS_IN,
} ep0_stage_t;

static ep0_stage_t ep0_stage = EP0_STAGE_IDLE;

void USBD_Handler(void)
{
    USB_EVENT_e eUsbEvt;
    USB_Type *ptUsb = (USB_Type *)USB_BASE;

    volatile uint32_t un32InEpEvent = 0, un32OutEpEvent = 0;
    volatile uint32_t un32CommonEvent = 0, un32Ep0Event = 0;

    un32CommonEvent = ptUsb->INTRUSB;
    un32OutEpEvent = ptUsb->INTROUT1;
    un32InEpEvent = ptUsb->INTRIN1;

#if 0
    //if (un32OutEpEvent != 0 || un32InEpEvent != 0)
        LOG("Com=0x%x|out=0x%x|in=0x%x\n", un32CommonEvent, un32OutEpEvent, un32InEpEvent);
#endif

    if (un32InEpEvent & 0x01)
    {
        ptUsb->INDEX = 0;
        un32Ep0Event = ptUsb->CSR0;

       if (un32Ep0Event == 0)
       {
           if (USBD_P_EP[0]) USBD_P_EP[0](USBD_EVT_IN);
       }

       if (s_un8FAddr != 0) 
       {
           HAL_USB_SetAddress(USB_ID_0, s_un8FAddr);
           s_un8FAddr = 0;
           USB_LOG("[S] Address Set\n");
       }

       if (un32Ep0Event & USB_EP0_EVENT_SENTSTALL)
       {
           HAL_USB_SetEPxControl(USB_ID_0, 0, 0);
       }

       if (un32Ep0Event & (USB_EP0_EVENT_SETUPEND | USB_EP0_EVENT_SRVSETUPEND)) 
       {
           USB_LOG("Setup End!\n");
           HAL_USB_SetEPxControl(USB_ID_0, 0, USB_EP0_CTRL_SRVSETUPEND);
           ep0_wait_data_out = 0;
       }

       if (un32Ep0Event & (USB_EP0_EVENT_OUTPKTRDY | USB_EP0_EVENT_SRVOUTPKTRDY)) 
       {
#if 0
#if 0
           uint16_t un16FifoCnt = 0;
           HAL_USB_GetEPxFifoCount(USB_ID_0, 0, (uint16_t *)&un16FifoCnt);
           if (un16FifoCnt == 8)
               if (USBD_P_EP[0]) USBD_P_EP[0](USBD_EVT_SETUP);
           else
               if (USBD_P_EP[0]) USBD_P_EP[0](USBD_EVT_OUT);
#else
           if (ep0_current_stage == EP0_STAGE_SETUP)
           {
               if (USBD_P_EP[0]) USBD_P_EP[0](USBD_EVT_SETUP);

               if ((USBD_SetupPacket.bmRequestType.Dir == REQUEST_HOST_TO_DEVICE) && 
                (USBD_SetupPacket.wLength > 0)) 
               {
                   ep0_current_stage = EP0_STAGE_DATA_OUT; 
               }

           }
           else if (ep0_current_stage == EP0_STAGE_DATA_OUT)
           {
               if (USBD_P_EP[0]) USBD_P_EP[0](USBD_EVT_OUT);

               if (USBD_EP0Data.Count == 0)
                   ep0_current_stage = EP0_STAGE_SETUP;
                      
           }
#endif
#endif


#if 1 
    if (ep0_wait_data_out)
    {
        /*
         * 직전 SETUP이 H2D data stage로 추정됨.
         * 이번 OUTPKTRDY/SRVOUTPKTRDY는 DATA OUT.
         */
        ep0_wait_data_out = 0;

        if (USBD_P_EP[0])
        {
            USBD_P_EP[0](USBD_EVT_OUT);
        }
    }
    else
    {
        /*
         * 기본은 SETUP으로 core에 전달.
         */
        ep0_setup_processing = 1;
        ep0_h2d_candidate    = 0;
        ep0_setup_stalled    = 0;
        ep0_status_in_zlp    = 0;

        if (USBD_P_EP[0])
        {
            USBD_P_EP[0](USBD_EVT_SETUP);
        }

        ep0_setup_processing = 0;

        /*
         * SETUP 처리 중:
         * - DirCtrlEP(H2D)가 호출되었고
         * - Stall이 없었고
         * - EP0 IN ZLP가 바로 나가지 않았으면
         * 다음 OUTPKTRDY는 DATA OUT으로 판단.
         */
        if ((ep0_h2d_candidate != 0U) &&
            (ep0_setup_stalled == 0U) &&
            (ep0_status_in_zlp == 0U))
        {
            ep0_wait_data_out = 1;
        }
        else
        {
            ep0_wait_data_out = 0;
        }
    }

#endif
       }

       if (un32Ep0Event & USB_EP0_EVENT_INPKTRDY) 
       {
           if (USBD_P_EP[0]) USBD_P_EP[0](USBD_EVT_IN);
       }
    }
    
    if (un32CommonEvent != 0) 
    {
        if (un32CommonEvent & USB_CM_EVENT_RESET) 
        {
            USBD_Reset();
            if (USBD_P_Reset_Event) USBD_P_Reset_Event();
        }

        if (un32CommonEvent & USB_CM_EVENT_SUSPEND) 
        {
            if (USBD_P_Suspend_Event) USBD_P_Suspend_Event();
        }

        if (un32CommonEvent & USB_CM_EVENT_RESUME) 
        {
            if (USBD_P_Resume_Event) USBD_P_Resume_Event();
        }
#if 1
        if (un32CommonEvent & USB_CM_EVENT_SOF) 
        {
            if (USBD_P_SOF_Event) USBD_P_SOF_Event();
        }
#endif
    }

    if (un32OutEpEvent != 0)
    {
        uint8_t u32Num = 31 - __clz(un32OutEpEvent);
#if 0
        if (u32Num == 1) {
            PB->BCR = 1 << 8;
            //PB->BSR = 1 << 8;
        }
#endif
        if (USBD_P_EP[u32Num]) USBD_P_EP[u32Num](USBD_EVT_OUT);
    }

    if ((un32InEpEvent & 0x1E) != 0)
    {
        uint8_t u32Num = 31 - __clz(un32InEpEvent);
        
        ptUsb->INDEX = u32Num;

        uint32_t un32InCsr = ptUsb->INCSR1;
#if 1
        if ((un32InCsr & 0x01) == 0)
        {
            //LOG("EP%d INPKTRDY is 0. Ignore Event.\n", u32Num);
            PB->BSR = 1 << 8;
        }
#if 0
        else
        {
            if (USBD_P_EP[u32Num]) USBD_P_EP[u32Num](USBD_EVT_IN);
        }
#else
        if (USBD_P_EP[u32Num]) USBD_P_EP[u32Num](USBD_EVT_IN);
#endif
#else
        if (USBD_P_EP[u32Num]) USBD_P_EP[u32Num](USBD_EVT_IN);
#endif
    }

    NVIC_EnableIRQ(USB_IRQn);
}

