/*
 *  Read USB Device Endpoint Data
 *    Parameters:      EPNum: Device Endpoint Number
 *                       EPNum.0..3: Address
 *                       EPNum.7:    Dir
 *                     pData: Pointer to Data Buffer
 *    Return Value:    Number of bytes read
 */

/* Done 1st */
U32 USBD_ReadEP(U32 EPNum, U8 *pData, U32 bufsz)
{
    uint8_t un8EpNum = (uint8_t)(EPNum & 0x0F);
    uint32_t un32FifoCnt = 0;

    HAL_USB_GetEPxFifoCount(USB_ID_0, un8EpNum, (uint16_t *)&un32FifoCnt);
    if (un32FifoCnt > bufsz)
    {
        un32FifoCnt = bufsz; 
    }

    HAL_USB_GetEPxFifo(USB_ID_0, un8EpNum, pData, (uint8_t)un32FifoCnt);

    if (un8EpNum == 0) 
    {
        HAL_USB_SetEPxControl(USB_ID_0, un8EpNum, USB_EP0_CTRL_SRVOUTPKTRDY);
#if 1
        if (un32FifoCnt == 8)
        {
            USB_LOG("0x%x|0x%x|0x%x\n", pData[0], pData[1], (pData[3] << 8 | pData[2]));
        }
#endif
    }
    else
    {
#if 0
        if (un8EpNum == 1)
            PB->BSR = 1 << 8;
#endif

#if 0
        uint32_t un32Reg;
        HAL_USB_GetEPxOutControl(USB_ID_0, un8EpNum, &un32Reg);

        un32Reg &= ~USB_EPX_OUT_CTRL_OUTPKTRDY;
        un32Reg &= ~USB_EPX_OUT_CTRL_FLUSHFIFO;
        un32Reg &= ~USB_EPX_OUT_CTRL_SENDSTALL;
        un32Reg &= ~USB_EPX_OUT_CTRL_CLRDATATOG;

        HAL_USB_SetEPxOutControl(USB_ID_0, un8EpNum, un32Reg);
#else
        HAL_USB_SetEPxOutControl(USB_ID_0, un8EpNum, USB_EPX_OUT_CTRL_OUTPKTRDY | USB_EPX_OUT_CTRL_FLUSHFIFO);
#endif        

        //HAL_USB_SetEPxOutControl(USB_ID_0, un8EpNum, USB_EPX_OUT_CTRL_OUTPKTRDY | USB_EPX_OUT_CTRL_FLUSHFIFO);
    }

    return (un32FifoCnt);
}


/*
 *  Write USB Device Endpoint Data
 *    Parameters:      EPNum: Device Endpoint Number
 *                       EPNum.0..3: Address
 *                       EPNum.7:    Dir
 *                     pData: Pointer to Data Buffer
 *                     cnt:   Number of bytes to write
 *    Return Value:    Number of bytes written
 */

extern USB_SETUP_PACKET USBD_SetupPacket;
extern USBD_EP_DATA USBD_EP0Data;

U32 USBD_WriteEP(U32 EPNum, U8 *pData, U32 cnt)
{
    uint8_t un8EpNum = EPNum & 0x0F;
	
    if (un8EpNum == 0)
    {
        if (cnt == 0)
        {
        if (ep0_setup_processing)
        {
            HAL_USB_SetEPxControl(USB_ID_0, un8EpNum, USB_EP0_CTRL_SRVOUTPKTRDY | USB_EP0_CTRL_DATAEND);
        }
        else
        {
            HAL_USB_SetEPxControl(USB_ID_0, un8EpNum, USB_EP0_CTRL_INPKTRDY | USB_EP0_CTRL_DATAEND);
        }
        ep0_status_in_zlp = 1;
        ep0_wait_data_out = 0;
        return (cnt);
        }
    }
    else
    {
        if (cnt == 0)
        {
            HAL_USB_SetEPxControl(USB_ID_0, un8EpNum, USB_EPX_CTRL_FLUSHFIFO);
            return (cnt);
        }
        
    }

    if (un8EpNum == 1)
        PB->BCR = 1 << 8;

    HAL_USB_SetEPxFifo(USB_ID_0, un8EpNum, pData, cnt);
#if DUMP
    for(int i = 0; i < cnt; i++)
        LOG("0x%x,",pData[i]);
#endif
    if (un8EpNum == 0)
    {
        uint32_t un32Flag = USB_EP0_CTRL_INPKTRDY;
			
        USB_LOG("EP0Data.Count %d:cnt %d\n",USBD_EP0Data.Count, cnt);
        if (*(volatile uint32_t *)&USBD_EP0Data.Count == cnt)
        {
            un32Flag |= USB_EP0_CTRL_DATAEND;
        }

        HAL_USB_SetEPxControl(USB_ID_0, un8EpNum, un32Flag);

        USB_LOG("EP0Data.Count %d:cnt %d:flag 0x%x\n",USBD_EP0Data.Count, cnt, un32Flag);
    }
    else
    {
        USB_LOG("EPx cnt=%d\n",cnt);
        HAL_USB_SetEPxControl(USB_ID_0, un8EpNum, USB_EPX_CTRL_INPKTRDY);
        USB_LOG("EPx WriteEnd!\n");
    }

#if 0
    if (un8EpNum == 1)
        PB->BSR = 1 << 8;
#endif

    return (cnt);
}

