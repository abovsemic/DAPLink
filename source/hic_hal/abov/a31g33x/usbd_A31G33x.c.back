typedef enum
{
    USB_EP0_RESP_NONE,   /* Only Data stage (ZLP) */
    USB_EP0_RESP_IN,     /* Device to Host data */
    USB_EP0_RESP_OUT,    /* Host to Device data */
    USB_EP0_RESP_STATUS, /* HW Status Stage */
    USB_EP0_RESP_NODATA,
    USB_EP0_RESP_STALL
} USB_EP0_RespType_e;

typedef struct
{
    USB_EP0_RespType_e type;
    uint8_t    *pData;
    uint16_t          length;
} USB_EP0_Response_t;

typedef struct
{
    const uint8_t *pBuf;
    uint16_t       total;
    uint16_t       sent;
    bool           needZlp;
} USB_EP0_TxCtx_t;

typedef struct
{
    uint8_t  *pBuf;
    uint16_t total;
    uint16_t recv;
} USB_EP0_RxState_t;

static USB_EP0_TxCtx_t s_ep0Tx;
static USB_EP0_RxState_t s_ep0Rx;

static CDC_LineCoding_t s_tCdcLineCoding = {
    .dwDTERate = 115200,
    .bCharFormat = 0,
    .bParityType = 0,
    .bDataBits = 8
};

#pragma pack(push, 1)
#pragma pack(push, 1)
typedef struct {
    USB_ConfigDescriptor_t    config;
    
    /* IAD (8 Bytes) */
    uint8_t  iad_bLength;
    uint8_t  iad_bDescriptorType;
    uint8_t  iad_bFirstInterface;
    uint8_t  iad_bInterfaceCount;
    uint8_t  iad_bFunctionClass;
    uint8_t  iad_bFunctionSubClass;
    uint8_t  iad_bFunctionProtocol;
    uint8_t  iad_iFunction;

    /* IF 0, 1 (CDC) */
    USB_InterfaceDescriptor_t if_comm;
    CDC_HeaderDesc_t          cdc_header;
    CDC_ACMDesc_t             cdc_acm;
    CDC_UnionDesc_t           cdc_union;
    USB_InterfaceDescriptor_t if_data;
    USB_EndpointDescriptor_t  cdc_ep_out;
    USB_EndpointDescriptor_t  cdc_ep_in;

    /* IF 2 (HID) */
    USB_InterfaceDescriptor_t if_hid;
    HID_HIDDesc_t             hid_desc;
    USB_EndpointDescriptor_t  hid_ep_out;
    USB_EndpointDescriptor_t  hid_ep_in;
} USB_CompositeConfigDescSet_t;

typedef struct
{
    /* Configuration */
    USB_ConfigDescriptor_t     config;

    /* Interface 0 : CDC Control (ACM) */
    USB_InterfaceDescriptor_t  if_comm;
    CDC_HeaderDesc_t           cdc_header;
    CDC_ACMDesc_t              cdc_acm;
    CDC_UnionDesc_t            cdc_union;

    /* Interface 1 : CDC Data */
    USB_InterfaceDescriptor_t  if_data;
    USB_EndpointDescriptor_t   ep_out;   // EP2 OUT
    USB_EndpointDescriptor_t   ep_in;    // EP1 IN

} USB_CDC_ConfigDescSet_t;

typedef struct
{
    /* Configuration */
    USB_ConfigDescriptor_t     config;

    /* Interface 0 : HID */
    USB_InterfaceDescriptor_t  if_hid;
    HID_HIDDesc_t              hid_desc;

    /* HID IN/OUT Endpoints */
    USB_EndpointDescriptor_t   ep_out;   // EP2 OUT
    USB_EndpointDescriptor_t   ep_in;    // EP2 IN

} USB_HID_ConfigDescSet_t;

#pragma pack(pop)

