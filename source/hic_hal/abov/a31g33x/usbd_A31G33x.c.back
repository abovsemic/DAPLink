} USB_EvtItem_t;

typedef struct {
    USB_EvtItem_t tItems[USB_EVT_QUEUE_SIZE];
    uint32_t un32Cnt;
    volatile uint8_t u8Head;
    volatile uint8_t u8Tail;
} USB_EvtQueue_t;

