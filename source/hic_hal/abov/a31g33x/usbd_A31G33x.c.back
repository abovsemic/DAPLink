/* Report Descriptor for test
 * Input  : 8 bytes
 * Output : 8 bytes
 */
static const uint8_t g_HID_ReportDesc[] =
{
    0x06, 0x00, 0xFF,      // Usage Page (Vendor Defined)
    0x09, 0x01,            // Usage (Vendor Usage 1)
    0xA1, 0x01,            // Collection (Application)

    /* Input Report (Device -> Host) */
    0x09, 0x02,            //   Usage
    0x15, 0x00,            //   Logical Min (0)
    0x26, 0xFF, 0x00,      //   Logical Max (255)
    0x75, 0x08,            //   Report Size (8 bits)
    0x95, 0x40,            //   Report Count (64 bytes) - EP MaxSizeì ì¼ì¹ ê¶ì¥
    0x81, 0x02,            //   Input (Data,Var,Abs)

    /* Output Report (Host -> Device) */
    0x09, 0x03,            //   Usage
    0x15, 0x00,            //   Logical Min (0)
    0x26, 0xFF, 0x00,      //   Logical Max (255)
    0x75, 0x08,            //   Report Size (8 bits)
    0x95, 0x40,            //   Report Count (64 bytes) - Inputê³¼ ë§ì¶ë ê² ìì 
    0x91, 0x02,            //   Output (Data,Var,Abs)

    0xC0                   // End Collection
};
